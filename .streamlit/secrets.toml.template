# TEMPLATE FOR .streamlit/secrets.toml
# Copy this to .streamlit/secrets.toml and fill in your actual values
# .streamlit/secrets.toml is added to .gitignore and NOT committed
#
# This is also the format to paste into Streamlit Cloud's
# "Manage app" -> Settings -> Secrets box.

ANTHROPIC_API_KEY = "sk-ant-api03-YOUR-KEY-HERE"
DEMO_MODE = "False"

# FamilySearch (optional, for live mode) — register an app at
# https://www.familysearch.org/developers/ and use its Client ID here.
# No personal login/password required for this grant.
FAMILYSEARCH_CLIENT_ID = "your-client-id-here"
FAMILYSEARCH_ENV = "integration"
