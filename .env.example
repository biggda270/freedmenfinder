# FREEDMENFINDER Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# Anthropic API Key
# Get from: https://console.anthropic.com/account/billing/overview
ANTHROPIC_API_KEY=sk-ant-api03-YOUR-KEY-HERE

# Use demo mode with mock data (recommended for testing)
# Set to False when you have Anthropic credits
DEMO_MODE=True

# FamilySearch (optional, for real mode)
# Register an app at: https://www.familysearch.org/developers/
# Uses the "Unauthenticated Session" OAuth grant (no personal login needed) —
# only your app's Client ID is required. See familysearch_client.py for what
# this does and doesn't give you access to.
FAMILYSEARCH_CLIENT_ID=your-client-id-here

# "integration" (FamilySearch's current name for what used to be called
# "sandbox") or "production". Start with integration.
FAMILYSEARCH_ENV=integration

# Optional escape hatch: set this to use a manually-obtained access token
# (e.g. from a one-time Authorization Code login) instead of the automatic
# Unauthenticated Session grant above. Leave blank to use the grant.
FAMILYSEARCH_ACCESS_TOKEN=
