# FREEDMENFINDER Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# Anthropic API Key
# Get from: https://console.anthropic.com/account/billing/overview
ANTHROPIC_API_KEY=sk-ant-api03-YOUR-KEY-HERE

# Use demo mode with mock data (recommended for testing)
# Set to False when you have Anthropic credits
DEMO_MODE=True

# FamilySearch API Token (optional, for real mode)
# Get from: https://developers.familysearch.org
FAMILYSEARCH_USERNAME=your-email@example.com
FAMILYSEARCH_PASSWORD=your-password-here
FAMILYSEARCH_ACCESS_TOKEN=your-access-token-here
